# ================================
# Banco de Dados (Supabase PostgreSQL)
# ================================
# Pegue a connection string do painel do Supabase:
# Project Settings > Database > Connection Pooling (Transaction ou Session mode)
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<SUA_SENHA>@aws-<REGIAO>.pooler.supabase.com:5432/postgres"

# ================================
# JWT
# ================================
# Gere uma chave segura com: openssl rand -hex 32
JWT_SECRET="sua-chave-secreta-aqui"
JWT_EXPIRES_IN="1d"

# ================================
# Seed — Admin padrão
# ================================
ADMIN_EMAIL="admin@spacedefenders.com"
ADMIN_PASSWORD="defina-uma-senha-forte-aqui"

# ================================
# OAuth — Google
# ================================
# Obtenha em: https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# ================================
# OAuth — GitHub
# ================================
# Obtenha em: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:3001/auth/github/callback"

# ================================
# OAuth — Facebook
# ================================
# Obtenha em: https://developers.facebook.com
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
FACEBOOK_CALLBACK_URL="http://localhost:3001/auth/facebook/callback"

# ================================
# E-mail (Resend)
# ================================
RESEND_API_KEY=""
MAIL_FROM="onboarding@resend.dev"
FRONTEND_URL="http://localhost:3000"